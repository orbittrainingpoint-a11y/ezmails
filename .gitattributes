# Force LF for everything checked out — this repo is deployed on Linux.
# Without this, Windows commits could ship CRLF and break bash/entrypoint scripts.
* text=auto eol=lf

# Always LF (scripts & configs executed on the server).
*.sh    text eol=lf
*.mjs   text eol=lf
*.cf    text eol=lf
*.conf  text eol=lf
*.sql   text eol=lf
*.ext   text eol=lf
Dockerfile text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
