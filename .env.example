# ──────────────────────────────────────────────────────────────
# ezmails environment configuration
# Copy to .env and fill in. The installer generates random secrets.
# File must be chmod 600 — never commit the real .env.
# ──────────────────────────────────────────────────────────────

# ── Application ──
NODE_ENV=production
TZ=UTC

# Single public domain. Webmail (email users) is served at https://${DOMAIN}/ — the
# common URL. The admin panel lives at a SECRET path under the same domain:
#   https://${DOMAIN}${ADMIN_BASE_PATH}
DOMAIN=mail.yourdomain.com
# Secret, hard-to-guess base path for the admin control panel (leading slash, no trailing).
# The installer generates a random one; change it any time and rebuild the frontend.
ADMIN_BASE_PATH=/control-CHANGEME

# CORS origins. With the secret-path layout both apps share ONE origin (the domain).
ADMIN_PANEL_URL=https://mail.yourdomain.com
WEBMAIL_URL=https://mail.yourdomain.com

# Webmail talks to the real Dovecot/Postfix stack. Keep this OFF in production
# (the DB-backed dev store is for local development only).
WEBMAIL_DEV_BYPASS_IMAP=false

# 512-bit hex (openssl rand -hex 64)
JWT_SECRET=CHANGE_ME
# Previous secret accepted for 24h during rotation (optional)
JWT_SECRET_PREVIOUS=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
SESSION_TTL_HOURS=24

# 32-byte hex (openssl rand -hex 32) — encrypts TOTP secrets & DKIM private keys at rest
TOTP_ENCRYPTION_KEY=CHANGE_ME

# bcrypt cost factor for app passwords
BCRYPT_COST=12

# ── PostgreSQL (single SQL DB: app data + mail tables) ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ezmails
POSTGRES_USER=ezmails
POSTGRES_PASSWORD=CHANGE_ME
# Prisma / app connection
DATABASE_URL=postgresql://ezmails:CHANGE_ME@postgres:5432/ezmails?schema=public

# Read-only-ish role Postfix & Dovecot use to query mail tables
MAIL_DB_USER=ezmails_mail
MAIL_DB_PASSWORD=CHANGE_ME

# ── Redis (sessions, rate limits, BullMQ, cache, pub/sub) ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ── Mail server ──
MAIL_HOSTNAME=mail.yourdomain.com
VMAIL_UID=5000
VMAIL_GID=5000
MAILDIR_ROOT=/var/mail/vhosts
DKIM_KEY_PATH=/var/lib/rspamd/dkim
DEFAULT_MAILBOX_QUOTA=1073741824
DEFAULT_ATTACHMENT_LIMIT=26214400

# Rspamd spam thresholds (overridable per-domain in UI)
RSPAMD_TAG_SCORE=6
RSPAMD_GREYLIST_SCORE=9
RSPAMD_REJECT_SCORE=15

# ── Webmail → mail stack ──
IMAP_HOST=dovecot
IMAP_PORT=993
SMTP_HOST=postfix
SMTP_PORT=587

# ── API ports (internal Docker network) ──
ADMIN_API_PORT=3001
WEBMAIL_API_PORT=3002

# ── Internal / workers ──
# Shared secret for node agents + log shippers calling internal endpoints.
INTERNAL_TOKEN=CHANGE_ME
# Set false to disable BullMQ workers (e.g. when running multiple API replicas).
ENABLE_WORKERS=true
NODE_AGENT_PORT=9101
LOG_RETENTION_DAYS=90
WEBMAIL_SESSION_TTL_HOURS=12
ATTACHMENT_LIMIT_BYTES=26214400
# Allow self-signed certs on the internal mail network during bootstrap.
MAIL_TLS_REJECT_UNAUTHORIZED=false

# ── TLS / Let's Encrypt ──
ACME_EMAIL=admin@yourdomain.com
ACME_DOMAINS=mail.yourdomain.com

# ── Outbound notifications (SMTP for system alerts) ──
ALERT_FROM=alerts@yourdomain.com
ALERT_TO=

# ── Optional: Cloudflare DNS automation ──
CLOUDFLARE_API_TOKEN=

# ── Titan features (webmail) ──
# AI Smart Write provider. Two options:
#  (a) Google Gemini  — get a key at https://aistudio.google.com/apikey
#  (b) OpenAI-compatible (recommended free option = Groq, no credit card):
#        https://console.groq.com → API Keys, then set:
#        AI_PROVIDER=openai
#        AI_API_KEY=gsk_xxx
#        AI_BASE_URL=https://api.groq.com/openai/v1
#        AI_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=gemini
AI_API_KEY=
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Public base URL used for campaign open-tracking pixels + booking links.
PUBLIC_BASE_URL=https://mail.yourdomain.com

# Reverse-DNS / mail HELO name should match DOMAIN. Set the VPS PTR record to DOMAIN
# in the Hostinger panel for best deliverability.
