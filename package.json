{
  "name": "ezmails",
  "version": "1.0.0",
  "private": true,
  "description": "ezmails — self-hosted, VPS-based enterprise email hosting platform",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:admin": "npm run dev -w @ezmails/admin-api",
    "dev:webmail": "npm run dev -w @ezmails/webmail-api",
    "dev:frontend": "npm run dev -w @ezmails/frontend",
    "db:generate": "npm run generate -w @ezmails/db",
    "db:push": "npm run push -w @ezmails/db",
    "db:migrate": "npm run migrate -w @ezmails/db",
    "db:seed": "npm run seed -w @ezmails/db",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
